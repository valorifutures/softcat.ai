---
interface Props {
  item: {
    name: string;
    category: string;
    why_radar: string;
    upvotes: number;
    ph_url: string;
  };
  index: number;
}

const { item, index } = Astro.props;
---

<a
  href={item.ph_url}
  target="_blank"
  rel="noopener noreferrer"
  class="block relative glass-card rounded-xl card-glow card-glow-red card-lift group animate-stagger border-l-2 border-l-neon-red/40 overflow-hidden"
  style={`--stagger-index: ${index}`}
>
  <div class="p-5 md:p-6">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <div class="flex items-center gap-3 mb-1">
          <h3 class="font-mono text-base font-bold text-text-bright group-hover:text-neon-red transition-colors">
            {item.name}
          </h3>
          <span class="shrink-0 px-1.5 py-0.5 rounded text-xs font-mono bg-surface-light text-text-muted">
            {item.category}
          </span>
        </div>
        <p class="text-sm text-text-muted leading-relaxed">{item.why_radar}</p>
      </div>
      <span class="font-mono text-xs text-neon-red shrink-0 flex items-center gap-1">
        &#9650; {item.upvotes}
      </span>
    </div>
  </div>
</a>
