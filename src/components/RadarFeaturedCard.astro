---
interface Props {
  item: {
    name: string;
    tagline: string;
    category: string;
    why_radar: string;
    maker: string;
    ph_url: string;
  };
  index: number;
}

const { item, index } = Astro.props;
---

<a
  href={item.ph_url}
  target="_blank"
  rel="noopener noreferrer"
  class="block relative glass-card rounded-xl card-glow card-glow-red card-lift group animate-stagger border-t-2 border-t-neon-red/40 overflow-hidden p-6 md:p-7"
  style={`--stagger-index: ${index}`}
>
  <div class="flex items-start justify-between gap-3 mb-3">
    <h3 class="font-mono text-lg font-bold text-text-bright group-hover:text-neon-red transition-colors">
      {item.name}
    </h3>
    <span class="shrink-0 px-2 py-0.5 rounded text-xs font-mono bg-neon-red/10 text-neon-red">
      {item.category}
    </span>
  </div>
  <p class="text-sm text-text-primary mb-3">{item.tagline}</p>
  <p class="text-sm text-text-muted leading-relaxed mb-4">{item.why_radar}</p>
  <div class="flex items-center justify-between">
    <span class="font-mono text-xs text-text-muted">by {item.maker}</span>
  </div>
</a>
