---
import allBots from '../data/pipeline/bots.json';

interface Props {
  generated_by?: string;
  model?: string;
  generation_time_s?: number;
  cost_usd?: number;
}

const { generated_by, model, generation_time_s, cost_usd } = Astro.props;

// Only render if we have pipeline metadata
if (!generated_by) return;

const bot = allBots.find((b) => b.id === generated_by);
const botName = bot?.name ?? generated_by;
const botScript = bot?.script ?? '';
const githubUrl = botScript
  ? `https://github.com/valorifutures/softcat.ai/blob/main/${botScript}`
  : '';

const parts: string[] = [];
if (model) {
  const shortModel = model.replace('claude-sonnet-4-20250514', 'Claude Sonnet').replace('claude-', 'Claude ');
  parts.push(shortModel);
}
if (generation_time_s != null) parts.push(`${generation_time_s}s`);
if (cost_usd != null) parts.push(`$${cost_usd.toFixed(3)}`);
---

<div class="flex items-center gap-2 font-mono text-xs text-text-muted/60 mt-4">
  <span class="text-neon-green/60">&#9632;</span>
  <span>generated by {botName}</span>
  {parts.length > 0 && (
    <span class="text-text-muted/40">&middot;</span>
  )}
  {parts.map((part, i) => (
    <>
      <span>{part}</span>
      {i < parts.length - 1 && <span class="text-text-muted/40">&middot;</span>}
    </>
  ))}
  {githubUrl && (
    <>
      <span class="text-text-muted/40">&middot;</span>
      <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-neon-green/50 hover:text-neon-green transition-colors">
        view bot source &rarr;
      </a>
    </>
  )}
</div>
