---
const navLinks = [
  { label: 'news & updates', href: '/news-and-updates', title: 'Latest AI news and updates' },
  { label: 'thoughts', href: '/thoughts', title: 'Observations and opinions' },
  { label: 'radar', href: '/radar', title: 'AI tools and launches worth knowing about' },
  { label: 'tools', href: '/tools', title: 'Things we use' },
  { label: 'prompts', href: '/prompts', title: 'Copy-ready AI prompts' },
  { label: 'lab', href: '/lab', title: 'Interactive experiments' },
];
---

<header class="border-b border-surface-light/50">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="font-mono font-bold text-lg text-text-bright group-hover:text-neon-green transition-colors">
        SOFT CAT
      </span>
      <span class="font-mono text-neon-green glow-green text-sm">.ai</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          title={link.title}
          class="font-mono text-sm text-text-muted hover:text-neon-cyan transition-colors"
        >
          {link.label}
        </a>
      ))}
      <button
        id="search-trigger"
        class="font-mono text-sm text-text-muted hover:text-neon-green transition-colors flex items-center gap-1.5"
        aria-label="Search"
        title="Search (Ctrl+K)"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <kbd class="hidden lg:inline text-[10px] px-1 py-0.5 rounded border border-surface-light/50 text-text-muted/50">&#8984;K</kbd>
      </button>
    </div>

    <!-- Mobile search + hamburger -->
    <div class="flex md:hidden items-center gap-2">
      <button
        id="search-trigger-mobile"
        class="font-mono text-text-muted hover:text-neon-green transition-colors p-1"
        aria-label="Search"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
      <button
        id="menu-toggle"
        class="font-mono text-text-muted hover:text-neon-cyan transition-colors p-1"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span id="menu-icon" class="text-lg">&#9776;</span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-surface-light/50">
    <div class="max-w-5xl mx-auto px-6 py-3 flex flex-col gap-3">
      {navLinks.map((link) => (
        <a
          href={link.href}
          title={link.title}
          class="font-mono text-sm text-text-muted hover:text-neon-cyan transition-colors py-1"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const icon = document.getElementById('menu-icon')!;

  toggle.addEventListener('click', () => {
    const open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden');
    icon.innerHTML = open ? '&#9776;' : '&#10005;';
    toggle.setAttribute('aria-expanded', String(!open));
  });

  // Wire up search buttons
  const openSearch = () => (window as any).__searchOpen?.();
  document.getElementById('search-trigger')?.addEventListener('click', openSearch);
  document.getElementById('search-trigger-mobile')?.addEventListener('click', openSearch);
</script>
