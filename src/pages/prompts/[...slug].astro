---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { tagDotClass } from '../../utils/tagColor';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('prompts');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="max-w-3xl mx-auto px-6 py-16">
    <header class="mb-8">
      <a href="/prompts" class="font-mono text-sm text-text-muted hover:text-neon-cyan transition-colors mb-4 inline-block">&larr; prompt library</a>
      <div class="flex items-center gap-3 mb-3">
        <span class="px-2 py-0.5 rounded text-xs font-mono bg-neon-amber/10 text-neon-amber">
          {entry.data.category}
        </span>
      </div>
      <h1 class="font-mono text-2xl font-bold text-text-bright glow-amber">{entry.data.title}</h1>
      <p class="text-text-muted mt-2">{entry.data.description}</p>
      {entry.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {entry.data.tags.map((tag) => (
            <span class="tag-badge">
              <span class={`tag-dot ${tagDotClass(tag)}`}></span>
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <div class="glow-divider mb-8" style="--divider-color: rgba(212, 165, 74, 0.15)"></div>

    <!-- Prompt block -->
    <div class="relative mb-8">
      <div class="flex items-center justify-between mb-3">
        <span class="font-mono text-xs text-text-muted uppercase tracking-widest">prompt</span>
        <button
          id="copy-btn"
          class="font-mono text-xs text-neon-amber hover:text-text-bright border border-neon-amber/30 hover:border-neon-amber/60 px-3 py-1 rounded transition-all"
        >
          copy
        </button>
      </div>
      <pre
        id="prompt-text"
        class="bg-surface border border-surface-light rounded-lg p-5 text-sm text-text-primary font-mono whitespace-pre-wrap leading-relaxed overflow-x-auto"
      >{entry.data.prompt}</pre>
    </div>

    <!-- Notes from the markdown body -->
    <div class="prose text-text-muted">
      <Content />
    </div>

    <div class="mt-10 pt-6 border-t border-surface-light">
      <a href="/prompts" class="font-mono text-sm text-text-muted hover:text-neon-amber transition-colors">
        &larr; back to prompt library
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-btn') as HTMLButtonElement;
  const pre = document.getElementById('prompt-text') as HTMLPreElement;

  btn.addEventListener('click', async () => {
    const text = pre.textContent ?? '';
    try {
      await navigator.clipboard.writeText(text);
      btn.textContent = 'copied!';
      setTimeout(() => { btn.textContent = 'copy'; }, 2000);
    } catch {
      btn.textContent = 'failed';
      setTimeout(() => { btn.textContent = 'copy'; }, 2000);
    }
  });
</script>
