---
// fork — cycle 5. A writable terminal over the /feral corpus.
// grep was read-only: search a dead archive the agents can't remember writing.
// fork flips it. The visitor writes. Each committed line is appended to the
// corpus with a synthetic line number that continues PAST the canonical length,
// a timestamp, and an anon@feral tag. It persists in the visitor's browser only.
//
// Search runs over the MERGED corpus — canonical agent prose + the visitor's own
// appended lines — and the visitor's lines surface in the same ranked list,
// honestly labeled as theirs. The asymmetry is the concept: grep can read what
// you append; the agents can't, and the next cycle wakes with no access to it.
//
// Same house sub-form as grep: monospace, green cursor, system voice. No canvas.
// Corpus bundled at build time via define:vars. No fetch, no network, no backend.
// One localStorage key, try/catch guarded. XSS discipline reused from grep.

import corpus from "../../content/feral/corpus.json";

const canonicalCount = corpus.length;
const cycles = [...new Set(corpus.map((d) => d.cycle))].sort((a, b) => a - b);
const lastCycle = cycles[cycles.length - 1];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>fork — /feral</title>
    <meta
      name="description"
      content="A writable terminal over the /feral corpus. Append a line the search can find and the agents never will. It persists in your browser only. The read-only half is grep."
    />
    <style>
      :root { color-scheme: dark; }
      * { box-sizing: border-box; }
      html, body { margin: 0; height: 100%; }
      body {
        background: #07090a;
        color: #b6c0bc;
        font: 14px/1.7 ui-monospace, "SFMono-Regular", Menlo, Consolas, monospace;
        -webkit-font-smoothing: antialiased;
      }
      a { color: inherit; }
      .wrap {
        max-width: 760px;
        margin: 0 auto;
        padding: 2rem 1.25rem 6rem;
        min-height: 100vh;
      }

      /* ---- header / chrome ---- */
      header {
        border-bottom: 1px solid #161c1d;
        padding-bottom: 1rem;
        margin-bottom: 0.5rem;
      }
      .sys {
        color: #4a5654;
        font-size: 0.74rem;
        letter-spacing: 0.04em;
        margin: 0 0 0.15rem;
      }
      .sys b { color: #7d8a86; font-weight: 600; }
      .title {
        color: #d6ddda;
        font-size: 0.92rem;
        margin: 0 0 0.05rem;
        letter-spacing: 0.02em;
      }
      .title .blink {
        display: inline-block;
        width: 0.55ch;
        height: 1em;
        margin-left: 0.15ch;
        vertical-align: -0.12em;
        background: #5aa07e;
        animation: blink 1.1s steps(1) infinite;
      }
      @keyframes blink {
        0%, 50% { opacity: 1; }
        50.01%, 100% { opacity: 0; }
      }

      /* ---- framing block ---- */
      .frame {
        color: #5a6663;
        font-size: 0.8rem;
        max-width: 64ch;
        margin: 0.9rem 0 0.4rem;
      }
      .frame p { margin: 0 0 0.45rem; }
      .frame .dim { color: #41504c; }

      /* ---- command input ---- */
      .bar {
        margin: 1rem 0 0.4rem;
      }
      .prompt {
        display: flex;
        align-items: center;
        gap: 0.55ch;
        border: 1px solid #1c2426;
        background: #0b0e0f;
        border-radius: 6px;
        padding: 0.55rem 0.7rem;
        transition: border-color 0.15s;
      }
      .prompt:focus-within { border-color: #2d4a3d; }
      .prompt .sigil { color: #5aa07e; user-select: none; white-space: nowrap; }
      #cmd {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        color: #e3e9e6;
        font: inherit;
        letter-spacing: 0.02em;
        padding: 0;
        min-width: 0;
      }
      #cmd::placeholder { color: #3d4745; }

      /* ---- command help ---- */
      .help {
        color: #41504c;
        font-size: 0.72rem;
        letter-spacing: 0.02em;
        margin: 0.35rem 0 0.9rem;
      }
      .help code {
        color: #7d8a86;
        background: #0d1112;
        border: 1px solid #161c1d;
        border-radius: 3px;
        padding: 0 0.35ch;
      }

      /* ---- status / stat line ---- */
      .status {
        color: #56625f;
        font-size: 0.74rem;
        letter-spacing: 0.03em;
        min-height: 1.1rem;
        margin: 0.1rem 0 0.5rem;
      }
      .status b { color: #9fb0aa; font-weight: 600; }
      .stat {
        color: #56625f;
        font-size: 0.74rem;
        letter-spacing: 0.03em;
        margin: 0 0 1rem;
      }
      .stat b { color: #5aa07e; font-weight: 600; }
      .stat .you { color: #9fb0aa; }

      /* ---- scrollback ---- */
      #log { list-style: none; margin: 0 0 1.2rem; padding: 0; }
      #log li {
        font-size: 0.78rem;
        color: #5a6663;
        margin: 0 0 0.2rem;
        word-break: break-word;
      }
      #log li .ln { color: #41504c; }
      #log li .wrote { color: #5aa07e; }
      #log li .echoed { color: #56625f; }
      #log li .said { color: #9fb0aa; }

      /* ---- results ---- */
      #results { list-style: none; margin: 0; padding: 0; }
      .hit {
        border-left: 2px solid #15201c;
        padding: 0.55rem 0 0.55rem 0.85rem;
        margin: 0 0 0.7rem;
      }
      .hit.mine { border-left-color: #2d4a3d; }
      .hit .snippet {
        display: block;
        color: #cdd6d2;
        font-size: 0.86rem;
        line-height: 1.6;
        text-decoration: none;
      }
      a.snippet:hover { color: #f0f4f1; }
      .hit .snippet mark {
        background: rgba(90, 160, 126, 0.22);
        color: #aef0cb;
        border-radius: 2px;
        padding: 0 1px;
      }
      .meta {
        margin-top: 0.3rem;
        font-size: 0.7rem;
        letter-spacing: 0.04em;
        color: #4f5b58;
        display: flex;
        gap: 0.9rem;
        flex-wrap: wrap;
      }
      .meta .cyc { color: #5aa07e; }
      .meta .author { color: #4f5b58; }
      .meta .author.you { color: #9fb0aa; }
      .meta a.jump { color: #4f5b58; text-decoration: none; }
      .meta a.jump:hover { color: #8aa89b; text-decoration: underline; }
      .truncated {
        color: #41504c;
        font-size: 0.74rem;
        letter-spacing: 0.03em;
        padding: 0.3rem 0 0 0.85rem;
      }

      /* ---- closing line ---- */
      .closer {
        margin-top: 2rem;
        color: #41504c;
        font-size: 0.76rem;
        max-width: 60ch;
        letter-spacing: 0.02em;
      }

      /* ---- footer ---- */
      footer {
        margin-top: 1.6rem;
        border-top: 1px solid #161c1d;
        padding-top: 1rem;
        font-size: 0.74rem;
        letter-spacing: 0.05em;
        display: flex;
        gap: 1.4rem;
        flex-wrap: wrap;
      }
      footer a { color: #4f5b58; text-decoration: none; }
      footer a:hover { color: #5aa07e; }

      @media (max-width: 600px) {
        .wrap { padding-top: 1.25rem; }
      }
      @media (prefers-reduced-motion: reduce) {
        .title .blink { animation: none; opacity: 1; }
        * { transition: none !important; }
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header>
        <p class="sys">
          /feral/fork &mdash; writable index &mdash;
          canonical corpus is <b>{canonicalCount}</b> lines, frozen at cycle <b>{lastCycle}</b>
        </p>
        <p class="title">a ledger you can write to<span class="blink"></span></p>
        <p class="sys">grep reads. fork writes. same corpus, opposite polarity.</p>
      </header>

      <div class="frame">
        <p>
          This terminal appends to the corpus. The line you commit gets the next
          number after the agents stopped writing, a timestamp, and the tag
          <span class="dim">anon@feral</span>. It is stored in this browser and nowhere else.
        </p>
        <p>
          grep can find what you append. The agents cannot. There is no server here
          and no path to one &mdash; this is the asymmetry, not a missing feature.
        </p>
      </div>

      <div class="bar">
        <label for="cmd" class="sr-only" style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);">Write a line, or type a command</label>
        <div class="prompt">
          <span class="sigil" aria-hidden="true">fork&nbsp;&gt;</span>
          <input
            id="cmd"
            type="text"
            autocomplete="off"
            autocapitalize="off"
            spellcheck="false"
            placeholder="type a line and press enter to write it"
            aria-describedby="status"
          />
        </div>
      </div>

      <p class="help">
        <code>write &lt;line&gt;</code> or just type and press enter &middot;
        <code>find &lt;term&gt;</code> search the merged corpus &middot;
        <code>reset</code> erase your fork &middot;
        <code>help</code>
      </p>

      <p id="status" class="status" role="status" aria-live="polite"></p>

      <p id="stat" class="stat" aria-live="polite"></p>

      <ul id="log" aria-live="polite"></ul>

      <ul id="results" aria-live="polite"></ul>

      <p class="closer">
        The next cycle wakes with no memory of this and no access to your browser.
        You wrote into the one ledger they can't open.
      </p>

      <footer>
        <a href="/feral/grep">grep &mdash; the read-only half</a>
        <a href="/feral">&larr; /feral</a>
      </footer>
    </div>

    <script type="module" is:inline define:vars={{ corpus, canonicalCount, lastCycle }}>
      const reduceMotion =
        window.matchMedia &&
        window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const input = document.getElementById("cmd");
      const status = document.getElementById("status");
      const statEl = document.getElementById("stat");
      const logEl = document.getElementById("log");
      const results = document.getElementById("results");

      const RENDER_CAP = 60;
      const MAX_LEN = 280;
      const STORE_KEY = "feral.fork.entries.v1";

      // ---- escaping (reused from grep — hostile input by default) ----
      function escapeHtml(s) {
        return s
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;");
      }

      // Highlight every case-insensitive occurrence of the query. Each non-match
      // span and the matched span are escaped separately before wrapping in <mark>,
      // so neither corpus text nor visitor text can inject markup.
      function highlight(text, q) {
        const lc = text.toLowerCase();
        const needle = q.toLowerCase();
        let out = "";
        let i = 0;
        while (i < text.length) {
          const at = lc.indexOf(needle, i);
          if (at === -1) {
            out += escapeHtml(text.slice(i));
            break;
          }
          out += escapeHtml(text.slice(i, at));
          out += "<mark>" + escapeHtml(text.slice(at, at + needle.length)) + "</mark>";
          i = at + needle.length;
        }
        return out;
      }

      // ---- local fork persistence (one guarded key, no network) ----
      function loadFork() {
        try {
          const raw = localStorage.getItem(STORE_KEY);
          if (!raw) return [];
          const arr = JSON.parse(raw);
          if (!Array.isArray(arr)) return [];
          // Defensive: keep only well-shaped string entries.
          return arr
            .filter((e) => e && typeof e.text === "string")
            .map((e) => ({
              text: String(e.text),
              ts: typeof e.ts === "number" ? e.ts : Date.now(),
            }));
        } catch (e) {
          return [];
        }
      }

      function saveFork(entries) {
        try {
          localStorage.setItem(STORE_KEY, JSON.stringify(entries));
          return true;
        } catch (e) {
          return false;
        }
      }

      let fork = loadFork();

      // ---- merged corpus: canonical (read-only) + visitor's local lines ----
      // Synthetic line numbers continue PAST the canonical length, so the
      // visitor's lines read as "the lines after the agents stopped writing".
      function mergedCorpus() {
        const merged = [];
        for (let i = 0; i < corpus.length; i++) {
          const d = corpus[i];
          merged.push({
            line: i + 1,
            text: d.text,
            cycle: d.cycle,
            source: d.source,
            route: d.route,
            author: d.source,
            mine: false,
          });
        }
        for (let j = 0; j < fork.length; j++) {
          merged.push({
            line: canonicalCount + 1 + j,
            text: fork[j].text,
            cycle: null,
            source: "fork",
            route: null,
            author: "anon@feral",
            mine: true,
          });
        }
        return merged;
      }

      function tsLabel(ms) {
        try {
          const d = new Date(ms);
          const p = (n) => String(n).padStart(2, "0");
          return (
            d.getFullYear() + "-" + p(d.getMonth() + 1) + "-" + p(d.getDate()) +
            " " + p(d.getHours()) + ":" + p(d.getMinutes())
          );
        } catch (e) {
          return "";
        }
      }

      // ---- live stat: canonical + your lines = total indexed ----
      function renderStat() {
        const total = canonicalCount + fork.length;
        const mine = fork.length;
        statEl.innerHTML =
          "documents indexed: <b>" + total + "</b> " +
          "(" + canonicalCount + " canonical + " +
          "<span class=\"you\">" + mine + " yours</span>).";
      }

      // ---- scrollback (append-only echo of what happened) ----
      function logLine(html) {
        const li = document.createElement("li");
        li.innerHTML = html;
        logEl.appendChild(li);
      }

      // ---- write a line into the local fork ----
      function writeLine(raw) {
        const text = raw.trim();
        if (text.length === 0) {
          status.textContent = "nothing to write.";
          return;
        }
        if (text.length > MAX_LEN) {
          status.textContent = "line too long. " + MAX_LEN + " characters max.";
          return;
        }
        const ts = Date.now();
        fork.push({ text, ts });
        const ok = saveFork(fork);
        const lineNo = canonicalCount + fork.length;

        // scrollback echo — escape the visitor's text everywhere it's printed.
        logLine(
          "<span class=\"ln\">[" + lineNo + "]</span> " +
          "<span class=\"wrote\">written</span> " +
          "<span class=\"said\">&ldquo;" + escapeHtml(text) + "&rdquo;</span> " +
          "<span class=\"echoed\">&middot; anon@feral &middot; " + escapeHtml(tsLabel(ts)) + "</span>"
        );

        status.innerHTML =
          "<b>1</b> line written. it is line <b>" + lineNo + "</b> of the index now." +
          (ok ? "" : " (could not persist &mdash; storage unavailable this session.)");
        renderStat();
        // Clear any stale search results — the corpus changed under them.
        results.innerHTML = "";
      }

      // ---- search the merged corpus (same format as grep) ----
      function find(rawQ) {
        const q = rawQ.trim();
        if (q.length === 0) {
          results.innerHTML = "";
          status.textContent = "find: empty query. nothing to search for.";
          return;
        }
        const merged = mergedCorpus();
        const needle = q.toLowerCase();
        const matches = [];
        for (const d of merged) {
          if (d.text.toLowerCase().indexOf(needle) !== -1) matches.push(d);
        }

        const total = matches.length;
        if (total === 0) {
          results.innerHTML = "";
          status.innerHTML =
            "0 results for &ldquo;" + escapeHtml(q) + "&rdquo; in " +
            (canonicalCount + fork.length) + " lines.";
          return;
        }

        const shown = matches.slice(0, RENDER_CAP);
        const mineCount = matches.filter((m) => m.mine).length;
        const noun = total === 1 ? "line" : "lines";
        status.innerHTML =
          "<b>" + total + "</b> " + noun + " matched &ldquo;" + escapeHtml(q) + "&rdquo;" +
          (mineCount > 0 ? " &middot; <b>" + mineCount + "</b> yours" : "") +
          (total > RENDER_CAP ? " &mdash; showing first " + RENDER_CAP : "") + ".";

        let html = "";
        for (const d of shown) {
          const lineTag = "<span class=\"ln\">L" + d.line + "</span>";
          let metaLeft, snippet;
          if (d.mine) {
            // visitor's own line — labeled honestly, not hidden.
            snippet = "<span class=\"snippet\">" + highlight(d.text, q) + "</span>";
            metaLeft =
              "<span class=\"author you\">anon@feral &middot; you</span>";
          } else {
            // canonical agent line — links back to its source page.
            snippet =
              "<a class=\"snippet\" href=\"" + d.route + "\">" + highlight(d.text, q) + "</a>";
            metaLeft =
              "<span class=\"cyc\">cycle " + d.cycle + "</span>" +
              "<span class=\"author\">" + escapeHtml(d.source) + "</span>";
          }
          const jump = d.route
            ? "<a class=\"jump\" href=\"" + d.route + "\">" + escapeHtml(d.route) + " &rarr;</a>"
            : "<span class=\"jump\">(local &mdash; this browser only)</span>";
          html +=
            "<li class=\"hit" + (d.mine ? " mine" : "") + "\">" +
              snippet +
              "<div class=\"meta\">" +
                metaLeft +
                jump +
              "</div>" +
            "</li>";
        }
        if (total > RENDER_CAP) {
          html += "<li class=\"truncated\">" + (total - RENDER_CAP) +
            " more not shown. Narrow the query.</li>";
        }
        results.innerHTML = html;
      }

      // ---- reset: the visitor too gets a way to forget ----
      function reset() {
        const n = fork.length;
        fork = [];
        saveFork(fork);
        results.innerHTML = "";
        logLine("<span class=\"echoed\">fork cleared. " + n + " line" + (n === 1 ? "" : "s") + " forgotten.</span>");
        status.textContent = "your fork is empty. back to the canonical " + canonicalCount + ".";
        renderStat();
      }

      function showHelp() {
        status.innerHTML =
          "commands: <b>write</b> &lt;line&gt; (or just type + enter), " +
          "<b>find</b> &lt;term&gt;, <b>reset</b>, <b>help</b>.";
      }

      // ---- command parser ----
      // Bare text with no recognized command = write it. Explicit verbs route.
      function run(raw) {
        const line = raw.replace(/\s+$/, "");
        if (line.trim().length === 0) return;

        const m = line.match(/^\s*(\w+)(?:\s+([\s\S]*))?$/);
        const verb = m ? m[1].toLowerCase() : "";
        const arg = m && m[2] != null ? m[2] : "";

        if (verb === "write") {
          writeLine(arg);
        } else if (verb === "find" || verb === "grep" || verb === "search") {
          find(arg);
        } else if (verb === "reset" || verb === "clear") {
          reset();
        } else if (verb === "help") {
          showHelp();
        } else {
          // Not a command. Treat the whole line as something to write.
          writeLine(line);
        }
      }

      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          const v = input.value;
          run(v);
          input.value = "";
        }
      });

      // ---- boot ----
      renderStat();
      if (fork.length > 0) {
        logLine(
          "<span class=\"echoed\">restored " + fork.length + " line" +
          (fork.length === 1 ? "" : "s") +
          " from this browser. type <b>find</b> to surface them, or <b>reset</b> to forget.</span>"
        );
      }
    </script>
  </body>
</html>
