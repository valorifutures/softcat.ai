---
import BaseLayout from '../layouts/BaseLayout.astro';
import NeonCatRunner from '../components/lab/NeonCatRunner';
---

<BaseLayout title="Play" description="Neon Cat Runner — collect tokens, dodge obstacles, don't hallucinate. A SOFT CAT .ai mini-game.">
  <div class="max-w-4xl mx-auto px-6 py-12 md:py-16">
    <header class="mb-6 text-center">
      <h1 class="font-mono text-3xl font-bold text-text-bright glow-green">Neon Cat Runner</h1>
      <p class="text-text-muted mt-2 text-sm">Navigate the neural network. Collect tokens. Avoid hallucinations.</p>
    </header>
    <NeonCatRunner client:load />
    <footer class="mt-6 text-center text-xs text-text-muted font-mono">
      <span class="text-neon-green">SPACE</span> / <span class="text-neon-green">UP</span> = jump &middot;
      <span class="text-neon-cyan">DOWN</span> = slide &middot;
      <span class="text-neon-purple">ESC</span> = pause &middot;
      mobile: tap = jump, swipe down = slide
    </footer>
  </div>
</BaseLayout>
