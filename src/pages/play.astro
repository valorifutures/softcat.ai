---
import BaseLayout from '../layouts/BaseLayout.astro';
import NeonCatRunner from '../components/lab/NeonCatRunner';
---

<BaseLayout title="Play" description="Neon Cat Runner — collect tokens, dodge obstacles, don't hallucinate. A SOFT CAT .ai mini-game.">
  <div class="max-w-4xl mx-auto px-2 md:px-6 py-6 md:py-16">
    <header class="mb-4 md:mb-6 text-center px-4">
      <h1 class="font-mono text-2xl md:text-3xl font-bold text-text-bright glow-green">Neon Cat Runner</h1>
      <p class="text-text-muted mt-1 md:mt-2 text-xs md:text-sm">Navigate the neural network. Collect tokens. Avoid hallucinations.</p>
      <p class="text-text-muted mt-1 text-xs">Born from a CEO-mode plan review between human and AI, powered by <a href="https://github.com/garrytan/gstack" target="_blank" rel="noopener" class="text-neon-cyan hover:underline">gstack</a>. Every sprite, sound, and line of code generated by our bots.</p>
    </header>
    <NeonCatRunner client:load />
    <footer class="mt-4 md:mt-6 text-center text-xs text-text-muted font-mono px-4 hidden md:block">
      <span class="text-neon-green">SPACE</span> / <span class="text-neon-green">UP</span> = jump &middot;
      <span class="text-neon-cyan">DOWN</span> = slide &middot;
      <span class="text-neon-purple">ESC</span> = pause
    </footer>
    <footer class="mt-3 text-center text-xs text-text-muted font-mono px-4 md:hidden">
      tap = jump &middot; swipe down = slide
    </footer>
  </div>
</BaseLayout>
