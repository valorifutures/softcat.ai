---
import PostLayout from '../../layouts/PostLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('news-and-updates');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const words = entry.body?.trim().split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(words / 200));

const allEntries = (await getCollection('news-and-updates')).filter((e) => !e.data.draft && e.id !== entry.id);
const relatedPosts = allEntries
  .filter((e) => e.data.tags.some((t) => entry.data.tags.includes(t)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((e) => ({ title: e.data.title, url: `/news-and-updates/${e.id}`, date: e.data.date }));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://softcat.ai" },
    { "@type": "ListItem", "position": 2, "name": "News & Updates", "item": "https://softcat.ai/news-and-updates" },
    { "@type": "ListItem", "position": 3, "name": entry.data.title, "item": `https://softcat.ai/news-and-updates/${entry.id}` },
  ],
};
---

<PostLayout
  title={entry.data.title}
  date={entry.data.date}
  tags={entry.data.tags}
  summary={entry.data.summary}
  backLink="/news-and-updates"
  backLabel="News & Updates"
  readingTime={readingTime}
  generated_by={entry.data.generated_by}
  model={entry.data.model}
  generation_time_s={entry.data.generation_time_s}
  cost_usd={entry.data.cost_usd}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <Content />
  {relatedPosts.length > 0 && <RelatedPosts posts={relatedPosts} />}
</PostLayout>
