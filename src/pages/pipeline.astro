---
import BaseLayout from '../layouts/BaseLayout.astro';
import allRuns from '../data/pipeline/runs.json';
import allBots from '../data/pipeline/bots.json';

const botMap = Object.fromEntries(allBots.map((b) => [b.id, b]));

// Sort runs newest first
const runs = [...allRuns].sort((a, b) => b.timestamp.localeCompare(a.timestamp));

// 7-day summary
const sevenDaysAgo = new Date(Date.now() - 7 * 86400000).toISOString();
const recentRuns = runs.filter((r) => r.timestamp >= sevenDaysAgo);
const totalRuns = recentRuns.length;
const successRuns = recentRuns.filter((r) => r.status === 'success').length;
const successRate = totalRuns > 0 ? Math.round((successRuns / totalRuns) * 100) : 0;
const totalCost = recentRuns.reduce((sum, r) => sum + (r.cost_usd ?? 0), 0);
const totalPublished = recentRuns.reduce((sum, r) => sum + (r.items_published ?? 0), 0);
const totalTokens = recentRuns.reduce((sum, r) => sum + (r.input_tokens ?? 0) + (r.output_tokens ?? 0), 0);

// Per-bot last run for roster
const lastRunByBot: Record<string, typeof runs[0]> = {};
for (const run of runs) {
  if (!lastRunByBot[run.bot]) lastRunByBot[run.bot] = run;
}

// Group runs by date for history
const runsByDate: Record<string, typeof runs> = {};
for (const run of runs.slice(0, 100)) {
  const date = run.timestamp.split('T')[0];
  if (!runsByDate[date]) runsByDate[date] = [];
  runsByDate[date].push(run);
}
const sortedDates = Object.keys(runsByDate).sort().reverse().slice(0, 14);

function relativeTime(isoStr: string): string {
  const now = new Date();
  const then = new Date(isoStr);
  const diffMs = now.getTime() - then.getTime();
  const mins = Math.floor(diffMs / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hours = Math.floor(mins / 60);
  if (hours < 24) return `${hours}h ago`;
  const days = Math.floor(hours / 24);
  return `${days}d ago`;
}

function botStatus(bot: typeof allBots[0]): { label: string; color: string } {
  const lastRun = lastRunByBot[bot.id];
  if (!lastRun) return { label: 'no data', color: 'text-text-muted/40' };
  if (lastRun.status === 'error') return { label: 'error', color: 'text-neon-red' };

  // Check if overdue: parse cron-style schedule for expected interval
  const now = new Date();
  const lastTime = new Date(lastRun.timestamp);
  const hoursSince = (now.getTime() - lastTime.getTime()) / 3600000;

  // Daily bots: overdue if >36h. Weekly bots: overdue if >10 days.
  const isWeekly = bot.schedule_cron.includes('* 0') || bot.schedule_cron.includes('* 3');
  const overdueThreshold = isWeekly ? 240 : 36;

  if (hoursSince > overdueThreshold) return { label: 'delayed', color: 'text-neon-amber' };
  return { label: 'operational', color: 'text-neon-green' };
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T00:00:00Z');
  return d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
}
---

<BaseLayout title="Pipeline" description="The machinery behind softcat.ai. Six bots, five feeds, one pipeline. See every run, every cost, every decision.">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <header class="mb-8">
      <a href="/" class="font-mono text-sm text-text-muted hover:text-neon-cyan transition-colors mb-4 inline-block">&larr; home</a>
      <h1 class="font-mono text-3xl font-bold text-text-bright glow-green">Pipeline</h1>
      <p class="text-text-muted mt-2">The machinery that builds this site. Every bot run, every cost, every output.</p>
    </header>

    <div class="section-banner mb-6" style="height: 120px; --banner-accent: rgba(78, 203, 143, 0.12); --banner-accent-mid: rgba(78, 203, 143, 0.04)" aria-hidden="true"></div>
    <div class="glow-divider mb-8" style="--divider-color: rgba(78, 203, 143, 0.15)"></div>

    <!-- 7-day summary -->
    {totalRuns > 0 ? (
      <section class="mb-12">
        <h2 class="font-mono text-xs text-neon-green uppercase tracking-widest mb-6">Last 7 days</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-surface border border-surface-light rounded-lg p-4">
            <div class="font-mono text-2xl font-bold text-text-bright">{totalRuns}</div>
            <div class="font-mono text-xs text-text-muted mt-1">bot runs</div>
          </div>
          <div class="bg-surface border border-surface-light rounded-lg p-4">
            <div class="font-mono text-2xl font-bold text-text-bright">{successRate}%</div>
            <div class="font-mono text-xs text-text-muted mt-1">success rate</div>
          </div>
          <div class="bg-surface border border-surface-light rounded-lg p-4">
            <div class="font-mono text-2xl font-bold text-text-bright">${totalCost.toFixed(2)}</div>
            <div class="font-mono text-xs text-text-muted mt-1">API cost</div>
          </div>
          <div class="bg-surface border border-surface-light rounded-lg p-4">
            <div class="font-mono text-2xl font-bold text-text-bright">{totalPublished}</div>
            <div class="font-mono text-xs text-text-muted mt-1">items published</div>
          </div>
        </div>
      </section>
    ) : (
      <section class="mb-12">
        <div class="bg-surface border border-surface-light rounded-lg p-8 text-center">
          <p class="font-mono text-sm text-text-muted">
            <span class="text-neon-green">&#9679;</span> Pipeline starting up. Run data will appear here after the first bot run.
          </p>
        </div>
      </section>
    )}

    <!-- Bot roster -->
    <section class="mb-12">
      <h2 class="font-mono text-xs text-neon-green uppercase tracking-widest mb-6">Bot roster</h2>
      <div class="grid gap-4">
        {allBots.map((bot) => {
          const status = botStatus(bot);
          const lastRun = lastRunByBot[bot.id];
          return (
            <div class="bg-surface border border-surface-light rounded-lg p-5">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-mono text-sm font-bold text-text-bright">{bot.name}</h3>
                    <span class={`font-mono text-xs flex items-center gap-1.5 ${status.color}`}>
                      <span>&#9679;</span> {status.label}
                    </span>
                  </div>
                  <p class="text-xs text-text-muted">{bot.description}</p>
                  <div class="flex flex-wrap items-center gap-3 mt-2 font-mono text-xs text-text-muted/60">
                    <span>{bot.schedule}</span>
                    {bot.model && <span>&middot; {bot.model.replace('claude-sonnet-4-20250514', 'Claude Sonnet')}</span>}
                    {bot.feeds.length > 0 && <span>&middot; {bot.feeds.length} feed{bot.feeds.length > 1 ? 's' : ''}</span>}
                  </div>
                </div>
                <div class="text-right shrink-0">
                  {lastRun ? (
                    <div class="font-mono text-xs text-text-muted/60">
                      <div>Last: {relativeTime(lastRun.timestamp)}</div>
                      {lastRun.cost_usd != null && <div>${lastRun.cost_usd.toFixed(3)}</div>}
                    </div>
                  ) : (
                    <span class="font-mono text-xs text-text-muted/40">no runs yet</span>
                  )}
                </div>
              </div>
              {bot.feeds.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {bot.feeds.map((feed) => (
                    <span class="px-1.5 py-0.5 rounded text-[10px] font-mono bg-surface-light text-text-muted/50">
                      {feed}
                    </span>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <!-- Run history -->
    <section class="mb-12">
      <h2 class="font-mono text-xs text-neon-green uppercase tracking-widest mb-6">Run history</h2>
      {sortedDates.length === 0 ? (
        <p class="font-mono text-sm text-text-muted/60">No runs recorded yet.</p>
      ) : (
        <div class="space-y-8">
          {sortedDates.map((dateStr) => (
            <div>
              <h3 class="font-mono text-xs text-text-muted mb-3">{formatDate(dateStr)}</h3>
              <div class="space-y-2">
                {runsByDate[dateStr].map((run) => {
                  const bot = botMap[run.bot];
                  return (
                    <div class="flex items-center gap-3 font-mono text-xs bg-surface border border-surface-light rounded-lg px-4 py-2.5">
                      <span class={`w-1.5 h-1.5 rounded-full shrink-0 ${run.status === 'error' ? 'bg-neon-red' : run.status === 'partial' ? 'bg-neon-amber' : 'bg-neon-green'}`}></span>
                      <span class="text-text-bright w-28 shrink-0 truncate">{bot?.name ?? run.bot}</span>
                      <span class="text-text-muted/60 w-16 shrink-0">{new Date(run.timestamp).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' })}</span>
                      <span class="text-text-muted/60 w-12 shrink-0">{run.duration_s}s</span>
                      {run.items_found > 0 && (
                        <span class="text-text-muted/50 hidden sm:inline">
                          {run.items_found} found &rarr; {run.items_published} published
                        </span>
                      )}
                      <span class="ml-auto text-text-muted/40">
                        {run.cost_usd != null ? `$${run.cost_usd.toFixed(3)}` : ''}
                      </span>
                    </div>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      )}
    </section>

    <!-- How it works -->
    <section class="mb-12">
      <div class="bg-surface border border-surface-light rounded-lg p-6">
        <h2 class="font-mono text-sm font-bold text-text-bright mb-3">How this works</h2>
        <div class="font-mono text-xs text-text-muted leading-relaxed space-y-2">
          <p>
            Six Python bots run on systemd timers on a dedicated server. Each bot scans
            RSS feeds, calls the Anthropic API to generate content, and commits the output
            directly to the GitHub repo. GitHub Actions builds the static site and deploys
            to GitHub Pages.
          </p>
          <p>
            Every bot run logs its metadata here: what it scanned, what it published, how
            long it took, and what it cost. This page reads that log at build time.
            What you're looking at is a static site that documents its own construction.
          </p>
          <p>
            The bots are open source.
            <a href="https://github.com/valorifutures/softcat.ai/tree/main/bot" target="_blank" rel="noopener noreferrer" class="text-neon-green hover:underline">View the code on GitHub &rarr;</a>
          </p>
        </div>
      </div>
    </section>

    <div class="mt-12 pt-8 border-t border-surface-light/50 text-center">
      <a href="#" class="font-mono text-xs text-text-muted hover:text-neon-green transition-colors">&uarr; back to top</a>
    </div>
  </div>
</BaseLayout>
